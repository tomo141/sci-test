{
  "name": "sci-test",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "questions:generate": "node scripts/enrich-question-feedback.mjs && node scripts/build-basic-v1-bank.mjs",
    "questions:build-knowledge": "vitest run src/lib/data/knowledgeBank.build.test.ts",
    "questions:calibrate-levels": "node scripts/calibrate-question-levels.mjs",
    "questions:level-distribution": "node scripts/report-question-level-distribution.mjs",
    "questions:audit-choices": "node scripts/audit-choice-plausibility.mjs",
    "questions:fix-choices": "node scripts/apply-choice-plausibility-fixes.mjs",
    "questions:import": "node scripts/import-question-bank.mjs",
    "questions:import:knowledge": "node scripts/import-question-bank.mjs supabase/seed/generated/questions-knowledge.json --published",
    "questions:validate-v5": "node scripts/validate-v5-batch.mjs",
    "questions:merge-v5": "node scripts/merge-v5-questions.mjs",
    "questions:v5-pipeline": "node scripts/validate-v5-batch.mjs && node scripts/merge-v5-questions.mjs && pnpm questions:build-knowledge && node scripts/audit-choice-plausibility.mjs --strict",
    "questions:generate-batch50": "node scripts/generate-batch50.mjs",
    "questions:validate-batch50": "node scripts/validate-batch50.mjs",
    "questions:merge-batch50": "node scripts/merge-batch50-questions.mjs",
    "questions:batch50-pipeline": "node scripts/generate-batch50.mjs && node scripts/validate-batch50.mjs && node scripts/merge-batch50-questions.mjs && pnpm questions:build-knowledge",
    "questions:import:basic-v1-archive": "node scripts/import-question-bank.mjs supabase/seed/generated/questions-basic-v1.json --status=archived",
    "preflight": "node scripts/preflight.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@11.7.0"
}
